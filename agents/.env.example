# Base64("ClientID:ClientSecret") — get from https://developers.sber.ru/studio
GIGACHAT_CREDENTIALS=your_base64_key_here

# API scope — choose one:
#   GIGACHAT_API_PERS  — personal (individuals)
#   GIGACHAT_API_B2B   — business, paid packages
#   GIGACHAT_API_CORP  — business, pay-as-you-go
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Disable CrewAI tracing prompt
CREWAI_TRACING_ENABLED=false
